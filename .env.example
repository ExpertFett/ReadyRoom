# --- Core ---
PORT=4700
# Where the SQLite file lives. On Railway, point this at the mounted volume, e.g. /data/readyroom.db
DB_PATH=./data/readyroom.db
# Random secret for signing session cookies. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-me

# Public base URL (used to build the Discord OAuth redirect). Locally this can be omitted.
# BASE_URL=https://readyroom.up.railway.app

# --- Discord OAuth (share the same Discord application as VectorBot / Mizmaker) ---
# Add "<BASE_URL>/auth/callback" as a redirect URI in the Discord developer portal.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Discord user IDs that are always super-admins (comma or space separated). Bootstrap your own ID here.
ROOT_ADMIN_IDS=

# --- Local development only ---
# Set to 1 to enable a no-Discord login bypass at /auth/dev-login (ignored when NODE_ENV=production).
ALLOW_DEV_LOGIN=1
